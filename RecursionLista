def suma_mayores_o_iguales(valor, lista):
    if not lista:
        return 0
    
    elemento_actual = lista.pop()
    

    suma_acumulada = suma_mayores_o_iguales(valor, lista)
    
    if elemento_actual >= valor:
        return elemento_actual + suma_acumulada
    else:
        return suma_acumulada

valores = [5, 12, 3, 8, 15, 2]
limite = 8

resultado = suma_mayores_o_iguales(limite, valores)
print(f"La suma recursiva es: {resultado}")
